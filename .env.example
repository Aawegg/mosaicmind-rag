# =================================================================
# MosaicMind environment.  Copy to .env and fill in.
# =================================================================

# --- Gemini (single key gives you Gemini 3.x, embeddings, vision, audio, video, Imagen, Veo, Lyria) ---
# Get one at https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_gemini_studio_key_here

# Gemini exposes an OpenAI-compatible endpoint, so we drive chat + embeddings through the openai SDK.
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# --- Groq (fast Llama + Whisper for audio transcription) ---
# Get one at https://console.groq.com/keys
GROQ_API_KEY=your_groq_key_here

# =================================================================
# Model routing
# =================================================================
# Top reasoning model — used by the LangGraph planner + final synthesizer.
MOSAIC_HEAVY_MODEL=gemini-3.1-pro-preview

# Fast model — used for query rewriting and tool-call-only nodes (sub-second).
# Options: gemini-3.1-flash-lite (Gemini), llama-3.3-70b-versatile (Groq).
MOSAIC_FAST_MODEL=gemini-3.1-flash-lite

# Multimodal model for native image / audio / video understanding.
MOSAIC_MM_MODEL=gemini-3.1-pro-preview

# Audio transcription via Groq (cheaper + faster than running Whisper locally).
# Set to "gemini" to use gemini-2.5-flash-native-audio-latest instead.
MOSAIC_ASR_PROVIDER=groq
MOSAIC_ASR_MODEL=whisper-large-v3-turbo

# Embeddings — Gemini's 3072-dim model via OpenAI-compat endpoint.
MOSAIC_TEXT_EMBED=gemini-embedding-001
MOSAIC_TEXT_EMBED_DIM=3072

# Image embedding model (local CLIP, no API needed).
MOSAIC_IMAGE_EMBED=clip-ViT-B-32

# =================================================================
# Storage
# =================================================================
MOSAIC_DATA_DIR=./data
MOSAIC_UPLOAD_DIR=./data/uploads
MOSAIC_INDEX_DIR=./data/index
MOSAIC_CHROMA_DIR=./data/chroma

# =================================================================
# MLflow
# =================================================================
MLFLOW_TRACKING_URI=./data/mlruns
MLFLOW_EXPERIMENT_NAME=mosaicmind

# =================================================================
# API
# =================================================================
MOSAIC_API_HOST=0.0.0.0
MOSAIC_API_PORT=8000
MOSAIC_LOG_LEVEL=INFO

# =================================================================
# AWS (optional, only for production deploy)
# =================================================================
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=mosaicmind-uploads
# AWS_OPENSEARCH_ENDPOINT=https://...
